<Application x:Class="WinPilot.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinPilot.ViewModels"
             xmlns:views="clr-namespace:WinPilot.Views"
             xmlns:conv="clr-namespace:WinPilot.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <conv:IsCurrentPageConverter x:Key="IsCurrentPage"/>
            <conv:LogLevelToBrushConverter x:Key="LogLevelToBrush"/>
            <conv:StepStatusToBrushConverter x:Key="StepStatusToBrush"/>

            <!-- Color Brushes -->
            <SolidColorBrush x:Key="BgBrush"          Color="#1E1E2E"/>
            <SolidColorBrush x:Key="SurfaceBrush"     Color="#2A2A3E"/>
            <SolidColorBrush x:Key="SidebarBrush"     Color="#16162A"/>
            <SolidColorBrush x:Key="AccentBrush"      Color="#3B82F6"/>
            <SolidColorBrush x:Key="SuccessBrush"     Color="#22C55E"/>
            <SolidColorBrush x:Key="WarningBrush"     Color="#F59E0B"/>
            <SolidColorBrush x:Key="ErrorBrush"       Color="#EF4444"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E2E8F0"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
            <SolidColorBrush x:Key="BorderBrush"      Color="#374151"/>
            <SolidColorBrush x:Key="NavActiveBrush"   Color="#1E3A5F"/>
            <SolidColorBrush x:Key="NavHoverBrush"    Color="#252545"/>

            <!-- Card Style -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="#2A2A3E"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="20"/>
            </Style>

            <!-- Typography -->
            <Style x:Key="CardTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#E2E8F0"/>
            </Style>
            <Style x:Key="CardLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#94A3B8"/>
                <Setter Property="Margin" Value="0,0,0,2"/>
            </Style>
            <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#64748B"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
            </Style>
            <Style x:Key="InfoValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
            </Style>

            <!-- ProgressBar Styles -->
            <Style x:Key="MetricProgressStyle" TargetType="ProgressBar">
                <Setter Property="Height" Value="4"/>
                <Setter Property="Foreground" Value="#3B82F6"/>
                <Setter Property="Background" Value="#374151"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style x:Key="DiskProgressStyle" TargetType="ProgressBar">
                <Setter Property="Height" Value="6"/>
                <Setter Property="Foreground" Value="#3B82F6"/>
                <Setter Property="Background" Value="#374151"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <!-- Button Styles -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#3B82F6"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2563EB"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#374151"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#374151"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="Padding" Value="12,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4B5563"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WarningButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#92400E"/>
                <Setter Property="Foreground" Value="#FDE68A"/>
                <Setter Property="Padding" Value="12,7"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PageButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#374151"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4B5563"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#252535"/>
                                    <Setter Property="Foreground" Value="#374151"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Nav Button Style -->
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#94A3B8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Margin="4,1" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#252545"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBox Style -->
            <Style x:Key="FilterComboStyle" TargetType="ComboBox">
                <Setter Property="Background" Value="#374151"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <!-- DatePicker Style -->
            <Style x:Key="FilterDatePickerStyle" TargetType="DatePicker">
                <Setter Property="Background" Value="#374151"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <!-- DataGrid Styles -->
            <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#252535"/>
                <Setter Property="Foreground" Value="#94A3B8"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush" Value="#374151"/>
            </Style>
            <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#CBD5E1"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#1E3A5F"/>
                        <Setter Property="Foreground" Value="#E2E8F0"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- DataTemplates for Navigation -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SystemInfoViewModel}">
                <views:SystemInfoView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EventViewerViewModel}">
                <views:EventViewerView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RecoveryViewModel}">
                <views:RecoveryView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RegistryViewModel}">
                <views:RegistryView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AboutViewModel}">
                <views:AboutView/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
