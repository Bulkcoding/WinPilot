<Window x:Class="WinPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:WinPilot.ViewModels"
        xmlns:conv="clr-namespace:WinPilot.Converters"
        mc:Ignorable="d"
        Title="WinPilot" Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI"
        WindowStyle="None"
        AllowsTransparency="False">
    <WindowChrome.WindowChrome>
        <!-- CaptionHeight="34": 타이틀바 34px 전체가 드래그 영역 (OS가 자동 처리) -->
        <WindowChrome CaptionHeight="34"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False"
                      GlassFrameThickness="1"/>
    </WindowChrome.WindowChrome>
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <conv:IsCurrentPageConverter x:Key="IsCurrentPage"/>

        <!-- 창 컨트롤 버튼 (최소화/최대화/닫기) -->
        <Style x:Key="WinCtrlStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WinCtrlCloseStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nav 버튼 기본 스타일 (active DataTrigger 포함) -->
        <Style x:Key="NavBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="4,1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/><!-- 타이틀바 -->
            <RowDefinition Height="*"/> <!-- 콘텐츠 -->
        </Grid.RowDefinitions>

        <!-- ===== 타이틀바 (WindowChrome CaptionHeight=34 → 이 영역 전체 드래그됨) ===== -->
        <Grid Grid.Row="0" Background="{DynamicResource SidebarBrush}">
            <!-- 좌측: W 타일 + WinPilot -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                <Border Width="22" Height="22" CornerRadius="5" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B82F6" Offset="0"/>
                            <GradientStop Color="#1D4ED8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="W" FontSize="12" FontWeight="Black" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="WinPilot" FontSize="12" FontWeight="SemiBold"
                           Foreground="#CBD5E1" Margin="7,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- 우측: 창 컨트롤 (IsHitTestVisibleInChrome=True → 클릭 가능) -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Stretch"
                        Orientation="Horizontal"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource WinCtrlStyle}" Click="MinimizeClick">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                </Button>
                <Button Style="{StaticResource WinCtrlStyle}" Click="MaximizeRestoreClick">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="&#xE922;"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowState,
                                                 RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="Maximized">
                                        <Setter Property="Text" Value="&#xE923;"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
                <Button Style="{StaticResource WinCtrlCloseStyle}" Click="CloseClick">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== 기본 모드 ===== -->
        <Grid Grid.Row="1" Visibility="{Binding IsNormalMode, Converter={StaticResource BoolToVisibility}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 사이드바 -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                            <Setter Property="Width" Value="220"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                            <Setter Property="Width" Value="60"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel>
                <!-- 로고 + 토글 -->
                <Border DockPanel.Dock="Top" Padding="12,14,12,14"
                        BorderBrush="#1A1A30" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <!-- 토글 버튼 -->
                        <Button DockPanel.Dock="Right" Command="{Binding ToggleSidebarCommand}"
                                Style="{StaticResource NavBtnStyle}"
                                Padding="4" Width="28" Height="28" VerticalAlignment="Center">
                            <TextBlock Text="☰" FontSize="14" Foreground="#475569"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- 확장: W(파랑) + inPilot(흰색) 텍스트 로고 -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="W" FontSize="22" FontWeight="Black"
                                       Foreground="#3B82F6" VerticalAlignment="Bottom"/>
                            <TextBlock Text="inPilot" FontSize="14" FontWeight="SemiBold"
                                       Foreground="#E2E8F0" VerticalAlignment="Bottom"
                                       Margin="0,0,0,2"/>
                        </StackPanel>

                        <!-- 접힘: 로고 없음 (토글만) -->
                    </DockPanel>
                </Border>

                <!-- 시스템 상태 (하단) -->
                <Border DockPanel.Dock="Bottom" Padding="12,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center"/>
                        <!-- 확장: 시스템 정상(IP) -->
                        <TextBlock Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"
                                   Text="{Binding SystemStatusText}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#CBD5E1"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 네비게이션 버튼들 -->
                <StackPanel Margin="0,8,0,0">

                    <!-- 대시보드 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Dashboard}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Dashboard"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="대시보드" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 시스템 정보 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding SystemInfo}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="SystemInfo"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="시스템 정보" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 이벤트 뷰어 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding EventViewer}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="EventViewer"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="이벤트 뷰어" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 작업 관리자 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding ProcessManager}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="ProcessManager"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE7F8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="작업 관리자" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 복구 도구 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Recovery}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Recovery"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="복구 도구" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 레지스트리 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Registry}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Registry"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="레지스트리" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- Ping 테스트 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Ping}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Ping"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="Ping 테스트" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- Defender 제외 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Defender}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Defender"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xEA18;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="Defender 제외" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 글자수 세기 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding TextCounter}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="TextCounter"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE8BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="글자수 세기" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 설정 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Settings}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Settings"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="설정" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 콘텐츠 영역 -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>

        </Grid>

        <!-- ===== 업데이트 모달 팝업 ===== -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="100"
              Background="#88000000"
              Visibility="{Binding ShowUpdatePopup, Converter={StaticResource BoolToVisibility}}">
            <Border Width="400"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="14" Padding="28,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
                </Border.Effect>
                <StackPanel>

                    <!-- 타이틀 + 닫기 -->
                    <DockPanel Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding DismissUpdatePopupCommand}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Width="28" Height="28" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                        <TextBlock Text="✕" FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock VerticalAlignment="Center" FontSize="17" FontWeight="SemiBold">
                            <Run Text="업데이트 " Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Run Text="{Binding LatestVersion}" Foreground="#3B82F6"/>
                        </TextBlock>
                    </DockPanel>

                    <!-- 구분선 -->
                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

                    <!-- 릴리즈 노트 -->
                    <ItemsControl ItemsSource="{Binding UpdateReleaseNotes}" Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,10">
                                    <Ellipse DockPanel.Dock="Left" Width="5" Height="5"
                                             Fill="#3B82F6" VerticalAlignment="Top" Margin="2,5,10,0"/>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}" LineHeight="20"/>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 릴리즈 노트 없을 때 fallback -->
                    <TextBlock Text="새 버전이 준비되었습니다."
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UpdateReleaseNotes.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- 다운로드 진행 -->
                    <StackPanel Margin="0,8,0,16"
                                Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar Value="{Binding DownloadProgress}" Maximum="100"
                                     Height="4" Foreground="#3B82F6" Margin="0,0,0,6"/>
                        <TextBlock Text="다운로드 중..." FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,12,0,16"/>

                    <!-- 버튼 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="나중에"
                                Command="{Binding DismissUpdatePopupCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="0,10"/>
                        <Button Grid.Column="2" Content="지금 업데이트"
                                Command="{Binding ApplyUpdateCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="0,10"
                                IsEnabled="{Binding UpdateReady}"/>
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== 미니 모드 ===== -->
        <Border Grid.Row="1"
                Visibility="{Binding IsMiniMode, Converter={StaticResource BoolToVisibility}}"
                Background="{DynamicResource SurfaceBrush}" VerticalAlignment="Top">
            <StackPanel Margin="16,14,16,16" DataContext="{Binding MiniVm}">

                <!-- 헤더 -->
                <DockPanel Margin="0,0,0,14">
                    <Button DockPanel.Dock="Right"
                            Content="⊡ 기본 모드"
                            Command="{Binding DataContext.ToggleMiniModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="8,4" FontSize="11"/>
                    <TextBlock Text="WinPilot" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </DockPanel>

                <!-- CPU -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="CPU" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding CpuUsage, StringFormat={}{0:F0}%}"
                               FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>

                <!-- 메모리(RAM) -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="메모리(RAM)" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding RamUsagePercent, StringFormat={}{0:F0}%}"
                                   FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding RamText}" FontSize="10"
                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>

                <!-- 운영 시간 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="운영 시간" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding UptimeText}"
                               FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                               TextAlignment="Right"/>
                </Grid>

                <!-- Windows -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Windows" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding OsVersion}"
                               FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                               TextAlignment="Right" TextWrapping="Wrap" MaxWidth="160"/>
                </Grid>

                <!-- 구분선 -->
                <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,16,0,16"/>

                <!-- 이벤트 뷰어 카운트 -->
                <DockPanel Margin="0,0,0,12">
                    <Border DockPanel.Dock="Right" CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#EF4444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EventCount}" Value="0">
                                        <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding EventCount}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="이벤트 뷰어 (경고 ~ 오류)" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </DockPanel>

                <!-- SFC 버튼 -->
                <Button Content="▶  SFC /scannow 시작"
                        Command="{Binding RunSfcCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,0,0,14"/>

                <!-- 시스템 상태 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center"/>
                    <TextBlock Text="시스템 정상" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</Window>
