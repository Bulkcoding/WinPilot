<Window x:Class="WinPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:WinPilot.ViewModels"
        xmlns:conv="clr-namespace:WinPilot.Converters"
        mc:Ignorable="d"
        Title="WinPilot" Height="720" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <conv:IsCurrentPageConverter x:Key="IsCurrentPage"/>

        <!-- Nav 버튼 기본 스타일 (active DataTrigger 포함) -->
        <Style x:Key="NavBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="4,1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 사이드바 -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                            <Setter Property="Width" Value="220"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                            <Setter Property="Width" Value="60"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel>
                <!-- 로고 + 토글 -->
                <Border DockPanel.Dock="Top" Padding="12,16,12,12" BorderBrush="#252545" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Command="{Binding ToggleSidebarCommand}"
                                Style="{StaticResource NavBtnStyle}" Padding="6" Width="32" Height="32">
                            <TextBlock Text="☰" FontSize="14" Foreground="#94A3B8"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="W" FontSize="20" FontWeight="Black" Foreground="#3B82F6"/>
                            <TextBlock Text="inPilot" FontSize="14" FontWeight="SemiBold" Foreground="#E2E8F0"
                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 시스템 상태 (하단) -->
                <Border DockPanel.Dock="Bottom" Padding="12,12">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center"/>
                        <TextBlock Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"
                                   Text="시스템 정상" Foreground="#64748B" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 네비게이션 버튼들 -->
                <StackPanel Margin="0,8,0,0">

                    <!-- 대시보드 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Dashboard}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Dashboard"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="대시보드" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 시스템 정보 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding SystemInfo}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="SystemInfo"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="시스템 정보" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 이벤트 뷰어 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding EventViewer}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="EventViewer"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="이벤트 뷰어" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 복구 도구 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Recovery}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Recovery"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="복구 도구" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 레지스트리 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Registry}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Registry"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="레지스트리" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- Ping 테스트 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Ping}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Ping"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="Ping 테스트" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- Windows 설정 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding WindowsSettings}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="WindowsSettings"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xEBC7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="Windows 설정" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 설정 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding Settings}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="Settings"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="설정" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>

                    <!-- 정보 -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="{Binding About}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <MultiBinding Converter="{StaticResource IsCurrentPage}">
                                                <Binding Path="CurrentPage"/>
                                                <Binding Path="About"/>
                                            </MultiBinding>
                                        </DataTrigger.Binding>
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel>
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#94A3B8" Width="24" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="정보" FontSize="13" Foreground="#CBD5E1" Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>
                        </DockPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 콘텐츠 영역 -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"/>
    </Grid>
</Window>
