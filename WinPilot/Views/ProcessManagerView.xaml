<UserControl x:Class="WinPilot.Views.ProcessManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>

        <!-- 이름 컬럼 셀: 가운데 정렬 -->
        <Style x:Key="NameCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>

        <!-- 모든 셀: 상하만 center (좌우는 Left) -->
        <Style x:Key="CCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
        </Style>

        <!-- 설명/경로 열: 동일하게 상하 center + 말줄임 -->
        <Style x:Key="DCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="TextTrimming"        Value="CharacterEllipsis"/>
        </Style>

        <!-- 프로세스 그리드 행: 섹션 헤더(앱/백그라운드) 행은 전체폭 배너로 템플릿 교체.
             일반 행은 공용 DataGridRowStyle 그대로 → 컬럼 정렬 유지. -->
        <Style x:Key="ProcRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSectionHeader}" Value="True">
                    <Setter Property="IsHitTestVisible" Value="False"/>
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridRow">
                                <Border Background="{DynamicResource AltRowBrush}" Padding="12,7"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <TextBlock Text="{Binding SectionTitle}" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 프로세스 그리드 셀: 선택 시 테마 반응 색(SelectionBrush) 사용.
             공용 DataGridCellStyle 은 선택 시 NavActiveBrush(테마 미반응 다크)를 칠해
             라이트 테마에서 선택 행이 어둡게 보였음 → 여기서 오버라이드. -->
        <Style x:Key="ProcCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource DataGridCellStyle}">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SelectionTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 서비스 상태 색상 -->
        <Style x:Key="StateCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextValueBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Running">
                    <Setter Property="Foreground" Value="#22C55E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Stopped">
                    <Setter Property="Foreground" Value="#EF4444"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <DockPanel Grid.Row="0" Margin="24,16,24,0">
            <Button DockPanel.Dock="Right"
                    Content="↺ 새로고침"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    VerticalAlignment="Center" Margin="8,0,0,0"/>

            <!-- 프로세스/자세히 탭: 작업 끝내기 -->
            <Button DockPanel.Dock="Right"
                    Content="작업 끝내기"
                    Command="{Binding EndTaskCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    VerticalAlignment="Center" Margin="8,0,0,0"
                    Visibility="{Binding ShowEndTask, Converter={StaticResource BoolToVisibility}}"/>

            <!-- 서비스 탭: 시작 / 중지 / 다시 시작 -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        Visibility="{Binding ShowServiceOps, Converter={StaticResource BoolToVisibility}}"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                <Button Content="시작"
                        Command="{Binding StartServiceCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="10,6"/>
                <Button Content="중지"
                        Command="{Binding StopServiceCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,6" Margin="6,0,0,0"/>
                <Button Content="다시 시작"
                        Command="{Binding RestartServiceCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,6" Margin="6,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="작업 관리자" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="12,0,0,0" VerticalAlignment="Bottom" Padding="0,0,0,2"/>
            </StackPanel>
        </DockPanel>

        <!-- 탭 -->
        <TabControl Grid.Row="1" Margin="16,8,16,16"
                    SelectedIndex="{Binding SelectedTab}"
                    Background="{DynamicResource BgBrush}"
                    BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="14,8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                        Background="Transparent" BorderThickness="0,0,0,2"
                                        BorderBrush="Transparent">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#F97316"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemRowBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ══════════════ 프로세스 탭 ══════════════ -->
            <TabItem Header="프로세스">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" Margin="0,8,0,8"
                             Text="{Binding ProcessFilter, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource ItemRowBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Padding="10,6" FontSize="12"/>
                    <DataGrid Grid.Row="1" x:Name="ProcessDataGrid"
                              ItemsSource="{Binding FlatGroups}"
                              SelectedItem="{Binding SelectedGroupItem}"
                              AutoGenerateColumns="False" CanUserReorderColumns="False"
                              CanUserResizeRows="False" IsReadOnly="True" SelectionMode="Single"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                              HeadersVisibility="Column"
                              Background="{DynamicResource SurfaceBrush}"
                              RowBackground="{DynamicResource SurfaceBrush}"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource ProcCellStyle}"
                              RowStyle="{StaticResource ProcRowStyle}"
                              EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                              Sorting="ProcessDataGrid_Sorting">
                        <!-- FullRow 선택색은 App 리소스의 SystemColors 오버라이드로 테마별 지정됨
                             (SettingsViewModel.ApplyTheme: 다크 #52525E / 라이트 #C7C4C1). -->
                        <DataGrid.Columns>

                            <!-- 이름 (토글 버튼 + 이름 + 카운트 뱃지) -->
                            <DataGridTemplateColumn Width="*" SortMemberPath="Name">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.Header>이름</DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center" Margin="2,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 토글 버튼 (다중 자식 그룹만) -->
                                            <Button Grid.Column="0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" Padding="0"
                                                    Command="{Binding DataContext.ToggleGroupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="▶"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Text" Value="▼"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>

                                            <!-- 자식 행 들여쓰기 -->
                                            <Border Grid.Column="1" Width="14"
                                                    Visibility="{Binding IsChild, Converter={StaticResource BoolToVisibility}}"/>

                                            <!-- 이름 + 카운트 뱃지 -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Width="16" Height="16" Source="{Binding IconSource}"
                                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <!-- Foreground 미지정 → DataGridCellStyle 상속 (선택 시 자동으로 밝은 색) -->
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChild}" Value="True">
                                                                    <Setter Property="Opacity" Value="0.75"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Border Margin="6,0,0,0" Padding="5,1" CornerRadius="8"
                                                        Background="#F97316"
                                                        Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisibility}}"
                                                        VerticalAlignment="Center" Opacity="0.85">
                                                    <TextBlock Text="{Binding ChildCount}" FontSize="10" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="상태"            Binding="{Binding Status}"     Width="80"  SortMemberPath="Status"     ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="CPU %"           Binding="{Binding CpuPercent, StringFormat={}{0:F1}%}" Width="70" SortMemberPath="CpuPercent" ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="메모리(MB)" Binding="{Binding MemoryMB, StringFormat={}{0:F1}}"    Width="100" SortMemberPath="MemoryMB"  ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="PID"             Binding="{Binding PidDisplay}" Width="65"  ElementStyle="{StaticResource CCell}" CanUserSort="False"/>
                            <DataGridTextColumn Header="설명"            Binding="{Binding Description}" Width="180" ElementStyle="{StaticResource DCell}" CanUserSort="False"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══════════════ 앱 기록 탭 ══════════════ -->
            <TabItem Header="앱 기록">
                <DataGrid ItemsSource="{Binding AppHistory}"
                          AutoGenerateColumns="False" CanUserReorderColumns="False"
                          CanUserResizeRows="False" IsReadOnly="True" SelectionMode="Single"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          HeadersVisibility="Column" Margin="0,8,0,0"
                          Background="{DynamicResource SurfaceBrush}"
                          RowBackground="{DynamicResource SurfaceBrush}"
                          BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                          ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                          CellStyle="{StaticResource DataGridCellStyle}"
                          RowStyle="{StaticResource DataGridRowStyle}"
                          EnableRowVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="이름" Width="*">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Width="16" Height="16" Source="{Binding IconSource}"
                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="CPU 시간"      Binding="{Binding CpuTimeText}"   Width="100" ElementStyle="{StaticResource CCell}"/>
                        <DataGridTextColumn Header="메모리 피크(MB)" Binding="{Binding PeakMemoryMB, StringFormat={}{0:F1}}" Width="110" ElementStyle="{StaticResource CCell}"/>
                        <DataGridTextColumn Header="인스턴스"      Binding="{Binding InstanceCount}" Width="80"  ElementStyle="{StaticResource CCell}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- ══════════════ 자세히 탭 ══════════════ -->
            <TabItem Header="자세히">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" Margin="0,8,0,8"
                             Text="{Binding ProcessFilter, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource ItemRowBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Padding="10,6" FontSize="12"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Details}"
                              SelectedItem="{Binding SelectedDetail}"
                              AutoGenerateColumns="False" CanUserReorderColumns="False"
                              CanUserResizeRows="False" IsReadOnly="True" SelectionMode="Single"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                              HeadersVisibility="Column"
                              Background="{DynamicResource SurfaceBrush}"
                              RowBackground="{DynamicResource SurfaceBrush}"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              EnableRowVirtualization="True">
                        <DataGrid.Columns>
                        <DataGridTemplateColumn Header="이름" Width="160">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Width="16" Height="16" Source="{Binding IconSource}"
                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                            <DataGridTextColumn Header="PID"        Binding="{Binding Pid}"         Width="65"  ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="상태"       Binding="{Binding Status}"      Width="80"  ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="CPU %"      Binding="{Binding CpuPercent, StringFormat={}{0:F1}%}" Width="70" ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="메모리(MB)" Binding="{Binding MemoryMB, StringFormat={}{0:F1}}"    Width="90" ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="사용자"     Binding="{Binding UserName}"    Width="130" ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="설명"       Binding="{Binding Description}" Width="200" ElementStyle="{StaticResource DCell}"/>
                            <DataGridTextColumn Header="경로"       Binding="{Binding Path}"        Width="*"   ElementStyle="{StaticResource DCell}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ══════════════ 서비스 탭 ══════════════ -->
            <TabItem Header="서비스">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" Margin="0,8,0,8"
                             Text="{Binding ServiceFilter, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource ItemRowBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Padding="10,6" FontSize="12"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Services}"
                              SelectedItem="{Binding SelectedService}"
                              AutoGenerateColumns="False" CanUserReorderColumns="False"
                              CanUserResizeRows="False" IsReadOnly="True" SelectionMode="Single"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                              HeadersVisibility="Column"
                              Background="{DynamicResource SurfaceBrush}"
                              RowBackground="{DynamicResource SurfaceBrush}"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              EnableRowVirtualization="True">
                        <DataGrid.Columns>
                        <DataGridTemplateColumn Header="표시 이름" Width="*">
                            <DataGridTemplateColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DataGridHeaderStyle}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTemplateColumn.HeaderStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Width="16" Height="16" Source="{Binding IconSource}"
                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                            <DataGridTextColumn Header="이름"      Binding="{Binding Name}"        Width="160" ElementStyle="{StaticResource CCell}"/>
                            <DataGridTemplateColumn Header="상태"  Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding State}" Style="{StaticResource StateCell}"
                                                   Padding="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="시작 유형" Binding="{Binding StartMode}"   Width="80"  ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="PID"       Binding="{Binding Pid}"         Width="65"  ElementStyle="{StaticResource CCell}"/>
                            <DataGridTextColumn Header="설명"      Binding="{Binding Description}" Width="220" ElementStyle="{StaticResource DCell}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
