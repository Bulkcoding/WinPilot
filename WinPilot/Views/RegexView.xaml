<UserControl x:Class="WinPilot.Views.RegexView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- 공통 모노스페이스 TextBox (ParserView CodeBox와 동일) -->
        <Style x:Key="CodeBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ConsoleBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ConsoleTextBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- 인라인 하이라이트용 RichTextBox (테스트 입력) -->
        <Style x:Key="CodeRtb" TargetType="RichTextBox">
            <Setter Property="Background" Value="{DynamicResource ConsoleBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ConsoleTextBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- 옵션 체크박스 -->
        <Style x:Key="OptCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
        </Style>

        <!-- 빈 문자열이면 숨기는 라벨 -->
        <Style x:Key="HideIfEmpty" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BgBrush}">
        <StackPanel Margin="2">

            <!-- ① AI 생성 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="자연어로 정규식 생성 (AI)" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding NlPrompt, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CodeBox}" MinHeight="56" FontFamily="Segoe UI"
                             d:Text="예: 한국 휴대폰 번호"/>
                    <DockPanel Margin="0,8,0,0">
                        <Button DockPanel.Dock="Left" Content="▶  생성"
                                Command="{Binding GenerateCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Padding="18,7"/>
                        <TextBlock Text="{Binding GenStatus}" Margin="12,0,0,0"
                                   VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </DockPanel>
                    <TextBlock Text="{Binding Explanation}" Style="{StaticResource HideIfEmpty}"
                               Foreground="{DynamicResource TextValueBrush}" FontSize="12"
                               TextWrapping="Wrap" Margin="0,10,0,0"/>
                    <TextBlock Text="키가 없어도 아래 테스터는 그대로 사용할 수 있습니다."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ② 패턴 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="복사"
                                Command="{Binding CopyPatternCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="12,4" FontSize="11"/>
                        <TextBlock Text="정규식 패턴" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBox Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CodeBox}" MinHeight="44"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <CheckBox Content="대소문자 무시 (i)" IsChecked="{Binding IgnoreCase}" Style="{StaticResource OptCheck}"/>
                        <CheckBox Content="여러 줄 ^$ (m)"   IsChecked="{Binding Multiline}"  Style="{StaticResource OptCheck}"/>
                        <CheckBox Content="한 줄 . = \n (s)" IsChecked="{Binding Singleline}"  Style="{StaticResource OptCheck}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding PatternError}" Style="{StaticResource HideIfEmpty}"
                               Foreground="#EF4444" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ③ 테스트 입력 (RichTextBox — 매치 구간을 인라인 하이라이트로 표시) -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="테스트 입력" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                    <RichTextBox x:Name="TestRtb"
                                 Style="{StaticResource CodeRtb}"
                                 MinHeight="110"
                                 TextChanged="OnTestRtbTextChanged">
                        <RichTextBox.Resources>
                            <Style TargetType="Paragraph">
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </RichTextBox.Resources>
                    </RichTextBox>
                </StackPanel>
            </Border>

            <!-- ④ 결과 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding MatchSummary}"
                                   Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="결과" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBox Text="{Binding MatchDetails, Mode=OneWay}" IsReadOnly="True"
                             Style="{StaticResource CodeBox}" MinHeight="120"/>
                </StackPanel>
            </Border>

            <!-- ⑤ 치환 -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="치환 (선택)" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Replacement, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CodeBox}" MinHeight="40"
                             d:Text="$1-$2"/>
                    <TextBlock Text="치환 결과" Style="{StaticResource CardTitleStyle}" FontSize="12" Margin="0,10,0,6"/>
                    <TextBox Text="{Binding ReplaceResult, Mode=OneWay}" IsReadOnly="True"
                             Style="{StaticResource CodeBox}" MinHeight="80"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
