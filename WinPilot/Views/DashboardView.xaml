<UserControl x:Class="WinPilot.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E2E">
        <StackPanel Margin="24,20,24,24">

            <!-- 헤더 -->
            <DockPanel Margin="0,0,0,20">
                <TextBlock Text="시스템 개요" FontSize="22" FontWeight="SemiBold"
                           Foreground="#E2E8F0" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="↺ 새로고침"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </DockPanel>

            <!-- 상단 메트릭 카드 4개 -->
            <UniformGrid Columns="4" Margin="0,0,0,16">

                <!-- CPU -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F0}%}"
                                   FontSize="36" FontWeight="Bold" Foreground="#E2E8F0" Margin="0,4,0,4"/>
                        <ProgressBar Value="{Binding CpuUsage}" Maximum="100"
                                     Style="{StaticResource MetricProgressStyle}"/>
                    </StackPanel>
                </Border>

                <!-- RAM -->
                <Border Style="{StaticResource CardStyle}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="메모리(RAM)" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding RamUsagePercent, StringFormat={}{0:F0}%}"
                                   FontSize="36" FontWeight="Bold" Foreground="#E2E8F0" Margin="0,4,0,4"/>
                        <ProgressBar Value="{Binding RamUsagePercent, Mode=OneWay}" Maximum="100"
                                     Style="{StaticResource MetricProgressStyle}"/>
                        <TextBlock Text="{Binding RamText}" FontSize="11" Foreground="#94A3B8" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 운영 시간 -->
                <Border Style="{StaticResource CardStyle}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="운영 시간" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding UptimeText}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="#E2E8F0" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Windows -->
                <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Windows" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{Binding OsVersion}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#E2E8F0" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 하단 2열 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽: 시스템 정보 + 메모리 차트 -->
                <StackPanel Grid.Column="0">
                    <!-- 시스템 상세 정보 -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="시스템 정보" Style="{StaticResource CardTitleStyle}"/>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CpuName}" Style="{StaticResource InfoValueStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="메모리" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RamText}" Style="{StaticResource InfoValueStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="디스크" Style="{StaticResource InfoLabelStyle}"/>
                                <ItemsControl Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Disks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,4">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource InfoValueStyle}" DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding UsagePercent, StringFormat={}{0:F0}%}"
                                                               Style="{StaticResource InfoValueStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                                                </DockPanel>
                                                <ProgressBar Value="{Binding UsagePercent, Mode=OneWay}" Maximum="100" Height="4"
                                                             Style="{StaticResource DiskProgressStyle}" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding UsedText, StringFormat={}사용: {0}}" FontSize="10"
                                                           Foreground="#64748B" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 메모리 사용량 차트 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="메모리 사용량" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding RamText}"
                                           Foreground="#3B82F6" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </DockPanel>
                            <Border Margin="0,12,0,0" Background="#1A1A2A" CornerRadius="4" Height="68" ClipToBounds="True">
                                <Canvas Width="300" Height="60" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <Canvas.LayoutTransform>
                                        <ScaleTransform/>
                                    </Canvas.LayoutTransform>
                                    <Polyline Points="{Binding SparklinePoints}"
                                              Stroke="#3B82F6" StrokeThickness="2"
                                              StrokeLineJoin="Round"/>
                                    <Rectangle Canvas.Left="0" Canvas.Top="0" Width="300" Height="60"
                                               Fill="#1A2535" Opacity="0.3"/>
                                </Canvas>
                            </Border>
                            <TextBlock Text="← 최근 60초" FontSize="10" Foreground="#475569" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 오른쪽: 이벤트 요약 + 복구 바로가기 -->
                <StackPanel Grid.Column="2">
                    <!-- 이벤트 뷰어 요약 -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="이벤트 뷰어 (경고 ~ 오류)" Style="{StaticResource CardTitleStyle}"/>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                    <RowDefinition Height="36"/>
                                </Grid.RowDefinitions>

                                <Ellipse Grid.Row="0" Grid.Column="0" Width="10" Height="10" Fill="#EF4444" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="오류" Foreground="#CBD5E1" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ErrorCount}" Foreground="#EF4444" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>

                                <Ellipse Grid.Row="1" Grid.Column="0" Width="10" Height="10" Fill="#F59E0B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="경고" Foreground="#CBD5E1" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding WarningCount}" Foreground="#F59E0B" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>

                                <Ellipse Grid.Row="2" Grid.Column="0" Width="10" Height="10" Fill="#3B82F6" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="정보" Foreground="#CBD5E1" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding InfoCount}" Foreground="#3B82F6" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="자세히 보기 →" FontSize="12" Foreground="#3B82F6"
                                       Margin="0,12,0,0" Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <!-- 시스템 복구 바로가기 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="시스템 복구" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock Text="시스템 파일 검사(SFC)를 실행하여 손상된 시스템 파일을 검사하고 복구합니다."
                                       Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,16"/>
                            <Button Content="▶ SFC /scannow 시작"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
