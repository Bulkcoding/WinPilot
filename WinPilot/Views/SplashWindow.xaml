<Window x:Class="WinPilot.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Width="320" Height="180"
        FontFamily="Pretendard, 맑은 고딕, Segoe UI">

    <Border Background="#1A1A22" CornerRadius="14" BorderBrush="#2A2A35" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="28">

            <!-- 로고: W 타일 + WinPilot -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                <Border Width="34" Height="34" CornerRadius="8" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F97316" Offset="0"/>
                            <GradientStop Color="#C2410C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="W" FontSize="18" FontWeight="Black" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="WinPilot" FontSize="20" FontWeight="SemiBold"
                           Foreground="#F3F4F6" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 진행 바 (무한 인디케이터) -->
            <ProgressBar x:Name="Bar" IsIndeterminate="True" Height="4" Width="240"
                         Background="#2A2A35" Foreground="#F97316" BorderThickness="0"/>

            <!-- 상태 텍스트 -->
            <TextBlock x:Name="StatusText" Text="시작하는 중..." FontSize="12"
                       Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,12,0,0"/>
        </StackPanel>
    </Border>
</Window>
