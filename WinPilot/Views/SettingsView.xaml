<UserControl x:Class="WinPilot.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <ScrollViewer Background="{DynamicResource BgBrush}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">
            <TextBlock Text="설정" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="테마" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <RadioButton Content="다크 모드"
                                     IsChecked="{Binding IsDarkTheme}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                     Margin="0,0,24,0" VerticalAlignment="Center"/>
                        <RadioButton Content="라이트 모드"
                                     IsChecked="{Binding IsDarkTheme, Converter={StaticResource InverseBoolConverter}}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                     VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="앱 재시작 없이 즉시 적용됩니다."
                               Foreground="#64748B" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- 버전 정보 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="버전 정보" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="현재 버전" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Width="80"/>
                            <TextBlock Text="{Binding CurrentVersionText}" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"/>
                        </StackPanel>
                        <!-- 업데이트 있을 때 최신 버전 표시 -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                    Visibility="{Binding DataContext.UpdateAvailable, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="최신 버전" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Width="80"/>
                            <TextBlock Text="{Binding DataContext.LatestVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Foreground="#3B82F6" FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"/>
                            <TextBlock Text=" · 업데이트 있음" Foreground="#3B82F6" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- 업데이트 버튼 -->
                    <Button Grid.Column="1"
                            Content="업데이트 보기"
                            Command="{Binding DataContext.ReopenUpdatePopupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Center"
                            Visibility="{Binding DataContext.UpdateAvailable, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>
            </Border>

            <!-- 폰트 크기 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="폰트 크기" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <RadioButton Content="보통"
                                     IsChecked="{Binding IsFontLarge, Converter={StaticResource InverseBoolConverter}}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                     Margin="0,0,24,0" VerticalAlignment="Center"/>
                        <RadioButton Content="크게"
                                     IsChecked="{Binding IsFontLarge}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                     VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="앱 재시작 없이 즉시 적용됩니다."
                               Foreground="#64748B" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- DeepSeek API 키 (이미지 텍스트 추출 AI 교정) -->
            <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="DeepSeek API 키" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                    <TextBlock Text="이미지 텍스트 추출 탭에서 OCR 후 AI 교정에 사용됩니다. 키를 설정하면 추출 후 자동으로 교정이 실행됩니다.&#x0a;※ 관리자만 수정 가능 — 저장/삭제 시 관리자 비밀번호가 필요합니다."
                               Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 상태 점 -->
                        <Ellipse Grid.Column="0" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDeepSeekKeySet}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
                            <!-- 보안상 키는 항상 ●●● 로 마스킹 표시 (PasswordBox).
                                 바인딩 불가하므로 코드비하인드에서 VM과 동기화. -->
                            <PasswordBox x:Name="DeepSeekPwdBox"
                                         PasswordChanged="OnDeepSeekPasswordChanged"
                                         FontSize="12" FontFamily="Consolas"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                                         VerticalAlignment="Center"/>
                        </Border>

                        <Button Grid.Column="2" Content="저장"
                                Command="{Binding SaveDeepSeekKeyCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="14,6" FontSize="12" Margin="0,0,6,0"/>

                        <Button Grid.Column="3" Content="삭제"
                                Command="{Binding DeleteDeepSeekKeyCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="14,6" FontSize="12"
                                IsEnabled="{Binding IsDeepSeekKeySet}"
                                ToolTip="저장된 DeepSeek API 키를 폐기합니다"/>
                    </Grid>
                    <TextBlock Text="{Binding DeepSeekStatus}" Foreground="{DynamicResource SuccessBrush}"
                               FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- 미니 모드 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="미니 모드" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                    <TextBlock Text="CPU, RAM, 운영 시간 등 주요 지표만 표시하는 컴팩트 창을 엽니다. 항상 위에 표시됩니다."
                               Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Button Command="{Binding DataContext.ToggleMiniModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="⊞  미니 모드로 전환"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsMiniMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Text" Value="⊡  기본 모드로 전환"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 미니 모드 전환 단축키 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="미니 모드 전환 단축키" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                    <TextBlock Text="앱이 백그라운드에 있어도 단축키로 미니 모드를 켜고 끌 수 있습니다."
                               Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <!-- 일반 표시 (클릭하면 캡처 모드로) -->
                    <Border Background="{DynamicResource ControlBrush}" CornerRadius="6" Padding="12,6"
                            Cursor="Hand"
                            PreviewMouseDown="OnStartCaptureHotkey"
                            Visibility="{Binding IsCapturingHotkey, Converter={StaticResource InverseBoolConverter}}">
                        <TextBlock Text="{Binding HotkeyDisplayText}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </Border>

                    <!-- 캡처 모드 -->
                    <Border x:Name="CaptureBorder"
                            Background="{DynamicResource ControlBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="2" CornerRadius="6" Padding="16,10"
                            Focusable="True"
                            PreviewKeyDown="OnCapturePreviewKeyDown"
                            Visibility="{Binding IsCapturingHotkey, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="⏺" FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="원하는 단축키를 누르세요 (두 키 동시에)…"
                                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
