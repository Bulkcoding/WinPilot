<UserControl x:Class="WinPilot.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <ScrollViewer Background="{DynamicResource BgBrush}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">
            <TextBlock Text="설정" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="테마" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <RadioButton Content="다크 모드"
                                     IsChecked="{Binding IsDarkTheme}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                     Margin="0,0,24,0" VerticalAlignment="Center"/>
                        <RadioButton Content="라이트 모드"
                                     IsChecked="{Binding IsDarkTheme, Converter={StaticResource InverseBoolConverter}}"
                                     Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                     VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="앱 재시작 없이 즉시 적용됩니다."
                               Foreground="#64748B" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- 미니 모드 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="미니 모드" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                    <TextBlock Text="CPU, RAM, 운영 시간 등 주요 지표만 표시하는 컴팩트 창을 엽니다. 항상 위에 표시됩니다."
                               Foreground="#64748B" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Button Command="{Binding DataContext.ToggleMiniModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left">
                        <Button.Content>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="⊞  미니 모드로 전환"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsMiniMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Text" Value="⊡  기본 모드로 전환"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
