<UserControl x:Class="WinPilot.Views.EventViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:WinPilot.Converters"
             mc:Ignorable="d">
    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </UserControl.InputBindings>
    <UserControl.Resources>
        <conv:LogLevelToBrushConverter x:Key="LevelToBrush"/>
        <Style x:Key="CenterCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <DockPanel Grid.Row="0" Margin="24,20,24,16">
            <Button DockPanel.Dock="Right" Content="↺ 새로고침"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    VerticalAlignment="Center"/>
            <TextBlock Text="이벤트 뷰어" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- 필터 -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Margin="24,0,24,12" CornerRadius="8" Padding="14,10">
            <WrapPanel>
                <ComboBox ItemsSource="{Binding LogFilters}" SelectedItem="{Binding SelectedLogFilter}"
                          Style="{StaticResource FilterComboStyle}" Width="120" Height="30" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding LevelFilters}" SelectedItem="{Binding SelectedLevelFilter}"
                          Style="{StaticResource FilterComboStyle}" Width="120" Height="30" Margin="0,0,10,0"/>
                <DatePicker SelectedDate="{Binding FromDate}"
                            Style="{StaticResource FilterDatePickerStyle}" Width="138" Height="30" Margin="0,0,6,0"/>
                <TextBlock Text="~" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker SelectedDate="{Binding ToDate}"
                            Style="{StaticResource FilterDatePickerStyle}" Width="138" Height="30"/>
                <TextBlock Text="{Binding TotalCount, StringFormat={}총 {0}건}"
                           Foreground="#64748B" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- 테이블 -->
        <Border Grid.Row="2" Margin="24,0,24,0">
            <DataGrid x:Name="EventGrid"
                      ItemsSource="{Binding Entries}"
                      SelectedItem="{Binding SelectedEntry}"
                      MouseDoubleClick="EventGrid_MouseDoubleClick"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeight="40"
                      Background="{DynamicResource SurfaceBrush}"
                      RowBackground="{DynamicResource SurfaceBrush}"
                      AlternatingRowBackground="{DynamicResource AltRowBrush}"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#374151"
                      HeadersVisibility="Column"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="수준" Width="60" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center"
                                         Fill="{Binding Level, Converter={StaticResource LevelToBrush}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="날짜 및 시간" Binding="{Binding DateTimeText}" Width="150" ElementStyle="{StaticResource CenterCell}"/>
                    <DataGridTextColumn Header="로그" Binding="{Binding LogName}" Width="90" ElementStyle="{StaticResource CenterCell}"/>
                    <DataGridTextColumn Header="이벤트 ID" Binding="{Binding EventId}" Width="80" ElementStyle="{StaticResource CenterCell}"/>
                    <DataGridTextColumn Header="원본" Binding="{Binding Source}" Width="180" ElementStyle="{StaticResource CenterCell}"/>
                    <DataGridTextColumn Header="설명" Binding="{Binding Description}" Width="*" ElementStyle="{StaticResource CenterCell}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 페이지네이션 -->
        <Border Grid.Row="3" Margin="24,12,24,16">
            <Grid>
                <TextBlock Text="{Binding TotalCount, StringFormat={}총 {0}개 항목}"
                           Foreground="#64748B" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="＜" Command="{Binding PreviousPageCommand}"
                            Style="{StaticResource PageButtonStyle}"/>
                    <TextBlock Margin="12,0" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13">
                        <Run Text="{Binding CurrentPage}"/>
                        <Run Text=" / " Foreground="#64748B"/>
                        <Run Text="{Binding TotalPages}"/>
                    </TextBlock>
                    <Button Content="＞" Command="{Binding NextPageCommand}"
                            Style="{StaticResource PageButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 상세 팝업 오버레이 -->
        <Grid Grid.RowSpan="4" Panel.ZIndex="20"
              Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVisibility}}">
            <Border Background="#CC1E1E2E"/>
            <Border Style="{StaticResource CardStyle}"
                    MaxWidth="700" MaxHeight="580" MinWidth="480"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,16">
                        <Button DockPanel.Dock="Right" Content="✕"
                                Command="{Binding CloseDetailCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="30" Height="30" Padding="0" FontSize="14"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="이벤트 상세 정보" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding SelectedEntry.DateTimeText}"
                                       Foreground="#64748B" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="수준" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedEntry.LevelText}"
                                               Foreground="{Binding SelectedEntry.Level, Converter={StaticResource LevelToBrush}}"
                                               FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="로그" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntry.LogName}"
                                               Foreground="{DynamicResource TextValueBrush}" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="이벤트 ID" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntry.EventId}"
                                               Foreground="{DynamicResource TextValueBrush}" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="원본" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedEntry.Source}"
                                               Foreground="{DynamicResource TextValueBrush}" FontSize="12" TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                            <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6" Padding="14,12">
                                <StackPanel>
                                    <TextBlock Text="설명" Foreground="#64748B" FontSize="12" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding SelectedEntry.FullDescription, Mode=OneWay}"
                                             Background="Transparent" Foreground="{DynamicResource TextValueBrush}"
                                             FontSize="12" IsReadOnly="True" TextWrapping="Wrap"
                                             BorderThickness="0" Padding="0"
                                             FontFamily="Consolas"
                                             Height="200"
                                             VerticalScrollBarVisibility="Auto"
                                             PreviewMouseWheel="DescriptionTextBox_PreviewMouseWheel"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
