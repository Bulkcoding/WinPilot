<UserControl x:Class="WinPilot.Views.DefenderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:svc="clr-namespace:WinPilot.Services"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BgBrush}">
        <StackPanel Margin="24,20,24,24">

            <!-- 헤더 -->
            <DockPanel Margin="0,0,0,20">
                <Button DockPanel.Dock="Right" Content="↺ 새로고침"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center"/>
                <TextBlock Text="Defender 제외 목록" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Tamper Protection 경고 -->
            <Border Visibility="{Binding TamperProtectionEnabled, Converter={StaticResource BoolToVisibility}}"
                    Background="{DynamicResource WarningBgBrush}" BorderBrush="#F59E0B"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,0,16" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="⚠ 변조 방지(Tamper Protection)가 켜져 있습니다"
                               Foreground="#F59E0B" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{DynamicResource TextValueBrush}" FontSize="12" Margin="0,4,0,0"
                               TextWrapping="Wrap">
                        Windows 보안 > 바이러스 및 위협 방지 설정 > 변조 방지를 끄면
                        WinPilot에서 제외 목록을 수정할 수 있습니다.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 제외 추가 카드 -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="제외 추가" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,14"/>

                    <!-- 종류 선택 -->
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="종류" Style="{StaticResource InfoLabelStyle}"
                                   Width="56" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="경로 (폴더/파일)"
                                         IsChecked="{Binding SelectedType,
                                             Converter={StaticResource EnumToBoolConverter},
                                             ConverterParameter=Path}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontSize="12" Margin="0,0,20,0" VerticalAlignment="Center"/>
                            <RadioButton Content="프로세스"
                                         IsChecked="{Binding SelectedType,
                                             Converter={StaticResource EnumToBoolConverter},
                                             ConverterParameter=Process}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontSize="12" Margin="0,0,20,0" VerticalAlignment="Center"/>
                            <RadioButton Content="확장자"
                                         IsChecked="{Binding SelectedType,
                                             Converter={StaticResource EnumToBoolConverter},
                                             ConverterParameter=Extension}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- 경로 입력 -->
                    <DockPanel>
                        <!-- 찾기 버튼 먼저 (DockPanel LastChildFill) -->
                        <Button DockPanel.Dock="Right" Content="+ 추가"
                                Command="{Binding AddCommand}"
                                IsEnabled="{Binding TamperProtectionEnabled,
                                            Converter={StaticResource InverseBoolConverter}}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="14,7" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="📁 찾기"
                                Command="{Binding BrowseFolderCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,7" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding TamperProtectionEnabled,
                                             Converter={StaticResource InverseBoolConverter}}"
                                 Background="{DynamicResource ItemRowBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                 Padding="10,7" FontSize="13" VerticalContentAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,6,0,0">
                        예) 경로: C:\MyApp   프로세스: myapp.exe   확장자: .log
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 현재 제외 목록 -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,14">
                        <ProgressBar DockPanel.Dock="Right" Width="60" Height="3"
                                     IsIndeterminate="True" Foreground="#F97316"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                                     VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="현재 제외 목록" Style="{StaticResource CardTitleStyle}"/>
                            <Border Background="{DynamicResource ControlBrush}" CornerRadius="10"
                                    Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Exclusions.Count}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </DockPanel>

                    <!-- 목록 없을 때 -->
                    <TextBlock Visibility="{Binding Exclusions.Count,
                                            Converter={StaticResource ZeroToVisibilityConverter}}"
                               Text="제외된 항목이 없습니다."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,20"/>

                    <!-- 제외 항목 목록 -->
                    <ItemsControl ItemsSource="{Binding Exclusions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6"
                                        Padding="14,10" Margin="0,0,0,6">
                                    <DockPanel>
                                        <!-- 삭제 버튼 먼저 -->
                                        <Button DockPanel.Dock="Right"
                                                Content="삭제"
                                                Command="{Binding DataContext.RemoveCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding DataContext.TamperProtectionEnabled,
                                                            RelativeSource={RelativeSource AncestorType=UserControl},
                                                            Converter={StaticResource InverseBoolConverter}}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="10,4" FontSize="11" VerticalAlignment="Center"/>
                                        <!-- 유형 아이콘 -->
                                        <TextBlock DockPanel.Dock="Left"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Width="24" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xE8DA;"/>
                                                    <!-- Path = folder icon -->
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}"
                                                                     Value="{x:Static svc:ExclusionType.Process}">
                                                            <Setter Property="Text" Value="&#xE7EF;"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}"
                                                                     Value="{x:Static svc:ExclusionType.Extension}">
                                                            <Setter Property="Text" Value="&#xE7C3;"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- 유형 라벨 -->
                                        <Border DockPanel.Dock="Left" CornerRadius="4" Padding="6,2"
                                                Margin="8,0,12,0" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#23232E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}"
                                                                     Value="{x:Static svc:ExclusionType.Process}">
                                                            <Setter Property="Background" Value="#3A2010"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}"
                                                                     Value="{x:Static svc:ExclusionType.Extension}">
                                                            <Setter Property="Background" Value="#1A3A1A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="경로"/>
                                                        <Setter Property="Foreground" Value="#F97316"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}"
                                                                         Value="{x:Static svc:ExclusionType.Process}">
                                                                <Setter Property="Text" Value="프로세스"/>
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}"
                                                                         Value="{x:Static svc:ExclusionType.Extension}">
                                                                <Setter Property="Text" Value="확장자"/>
                                                                <Setter Property="Foreground" Value="#22C55E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <!-- 경로/값 -->
                                        <TextBlock Text="{Binding Value}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="13" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
