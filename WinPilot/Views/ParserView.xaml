<UserControl x:Class="WinPilot.Views.ParserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- 탭 스타일 -->
        <Style x:Key="ParserTabStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#F97316"/>
                                <Setter TargetName="Tb" Property="Foreground"   Value="#F97316"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tb" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 에러 텍스트 -->
        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- 라벨 -->
        <Style x:Key="AreaLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- 아이콘 버튼 (복사/지우기) -->
        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 공통 TextBox -->
        <Style x:Key="CodeBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ConsoleBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ConsoleTextBrush}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <DockPanel Grid.Row="0" Margin="24,20,24,0">
            <TextBlock Text="파서" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
        </DockPanel>

        <!-- 탭 컨트롤 -->
        <TabControl Grid.Row="1" Margin="24,12,24,24"
                    Background="Transparent" BorderThickness="0"
                    Padding="0">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </TabControl.Resources>
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- 탭 헤더 -->
                        <TabPanel Grid.Row="0" IsItemsHost="True"
                                  Background="Transparent" Margin="0,0,0,0"/>
                        <!-- 구분선 -->
                        <Rectangle Grid.Row="1" Height="1"
                                   Fill="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>
                        <!-- 탭 내용 -->
                        <ContentPresenter Grid.Row="2" ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <!-- ═══ JWT ══════════════════════════════════════════ -->
            <TabItem Header="JWT" Style="{StaticResource ParserTabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="100"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <!-- 입력 -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="지우기"
                                        Command="{Binding ClearJwtCommand}"
                                        Style="{StaticResource IconBtnStyle}"/>
                                <TextBlock Text="JWT 토큰 입력" Style="{StaticResource AreaLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>
                            <TextBox Grid.Row="1" Style="{StaticResource CodeBox}" MinHeight="80"
                                     Text="{Binding JwtInput, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </Border>

                    <!-- 버튼 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="▶  파싱" Command="{Binding ParseJwtCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Padding="20,7" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding JwtError}" Style="{StaticResource ErrorText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 결과 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 헤더 -->
                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Content="복사"
                                            Command="{Binding CopyJwtHeaderCommand}"
                                            Style="{StaticResource IconBtnStyle}"/>
                                    <TextBlock Text="Header" Style="{StaticResource AreaLabel}"
                                               VerticalAlignment="Center" Margin="0"/>
                                </DockPanel>
                                <TextBox Grid.Row="1" Style="{StaticResource CodeBox}"
                                         Text="{Binding JwtHeader, Mode=OneWay}"
                                         IsReadOnly="True"/>
                            </Grid>
                        </Border>

                        <!-- 페이로드 -->
                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Content="복사"
                                            Command="{Binding CopyJwtPayloadCommand}"
                                            Style="{StaticResource IconBtnStyle}"/>
                                    <TextBlock Text="Payload" Style="{StaticResource AreaLabel}"
                                               VerticalAlignment="Center" Margin="0"/>
                                </DockPanel>
                                <TextBox Grid.Row="1" Style="{StaticResource CodeBox}"
                                         Text="{Binding JwtPayload, Mode=OneWay}"
                                         IsReadOnly="True"/>
                                <!-- 서명 -->
                                <Border Grid.Row="2" Background="{DynamicResource ItemRowBrush}"
                                        CornerRadius="6" Padding="10,6" Margin="0,8,0,0">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="Signature  "
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding JwtSignature}"
                                                   Foreground="#F59E0B" FontFamily="Consolas" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══ Base64 ════════════════════════════════════════ -->
            <TabItem Header="Base64" Style="{StaticResource ParserTabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 입력 -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="지우기"
                                        Command="{Binding ClearBase64Command}"
                                        Style="{StaticResource IconBtnStyle}"/>
                                <TextBlock Text="입력" Style="{StaticResource AreaLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>
                            <TextBox Grid.Row="1" Style="{StaticResource CodeBox}"
                                     Text="{Binding Base64Input, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <!-- 버튼 -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="인코딩 →" Command="{Binding EncodeBase64Command}"
                                Style="{StaticResource PrimaryButtonStyle}" Padding="16,7" Margin="0,0,8,0"/>
                        <Button Content="← 디코딩" Command="{Binding DecodeBase64Command}"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="16,7" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding Base64Error}" Style="{StaticResource ErrorText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 출력 -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="복사"
                                        Command="{Binding CopyBase64OutputCommand}"
                                        Style="{StaticResource IconBtnStyle}"/>
                                <TextBlock Text="결과" Style="{StaticResource AreaLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>
                            <TextBox Grid.Row="1" Style="{StaticResource CodeBox}"
                                     Text="{Binding Base64Output, Mode=OneWay}"
                                     IsReadOnly="True"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ JSON ═════════════════════════════════════════ -->
            <TabItem Header="JSON" Style="{StaticResource ParserTabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="지우기"
                                        Command="{Binding ClearJsonCommand}"
                                        Style="{StaticResource IconBtnStyle}"/>
                                <TextBlock Text="JSON 입력" Style="{StaticResource AreaLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>
                            <TextBox Grid.Row="1" Style="{StaticResource CodeBox}"
                                     Text="{Binding JsonInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="▶  포맷" Command="{Binding FormatJsonCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Padding="16,7" Margin="0,0,8,0"/>
                        <Button Content="압축" Command="{Binding MinifyJsonCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Padding="16,7" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding JsonError}" Style="{StaticResource ErrorText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="복사"
                                        Command="{Binding CopyJsonOutputCommand}"
                                        Style="{StaticResource IconBtnStyle}"/>
                                <TextBlock Text="결과" Style="{StaticResource AreaLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>
                            <TextBox Grid.Row="1" Style="{StaticResource CodeBox}"
                                     Text="{Binding JsonOutput, Mode=OneWay}"
                                     IsReadOnly="True"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══ XML ══════════════════════════════════════════ -->
            <TabItem Header="XML" Style="{StaticResource ParserTabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="지우기"
                                        Command="{Binding ClearXmlCommand}"
                                        Style="{StaticResource IconBtnStyle}"/>
                                <TextBlock Text="XML 입력" Style="{StaticResource AreaLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>
                            <TextBox Grid.Row="1" Style="{StaticResource CodeBox}"
                                     Text="{Binding XmlInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="▶  포맷" Command="{Binding FormatXmlCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" Padding="16,7" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding XmlError}" Style="{StaticResource ErrorText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                <Button DockPanel.Dock="Right" Content="복사"
                                        Command="{Binding CopyXmlOutputCommand}"
                                        Style="{StaticResource IconBtnStyle}"/>
                                <TextBlock Text="결과" Style="{StaticResource AreaLabel}"
                                           VerticalAlignment="Center" Margin="0"/>
                            </DockPanel>
                            <TextBox Grid.Row="1" Style="{StaticResource CodeBox}"
                                     Text="{Binding XmlOutput, Mode=OneWay}"
                                     IsReadOnly="True"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
