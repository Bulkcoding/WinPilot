<UserControl x:Class="WinPilot.Views.RegistryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="24,20,24,16">
            <TextBlock Text="레지스트리 바로가기" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,0,24,24">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="자주 사용하는 레지스트리 경로에 빠르게 접근합니다."
                                   Foreground="#94A3B8" FontSize="12" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding Shortcuts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6" Padding="16,14" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Description}" Foreground="#94A3B8"
                                                           FontSize="11" Margin="0,3,0,0"/>
                                                <TextBlock Text="{Binding Path}" Foreground="#475569"
                                                           FontSize="10" FontFamily="Consolas"
                                                           Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="regedit에서 열기"
                                                    Command="{Binding DataContext.OpenInRegeditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
