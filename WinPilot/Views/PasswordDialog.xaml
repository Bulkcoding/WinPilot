<Window x:Class="WinPilot.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="관리자 인증"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BgBrush}">
    <StackPanel Margin="24,20,24,20">
        <TextBlock Text="관리자 인증"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBlock Text="DeepSeek API 키는 관리자만 수정할 수 있습니다. 비밀번호를 입력하세요."
                   FontSize="12" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,6,0,12"/>

        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="10,6">
            <PasswordBox x:Name="PwdBox"
                         FontSize="14"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                         KeyDown="OnPasswordKeyDown"/>
        </Border>

        <TextBlock x:Name="ErrorText" Text="비밀번호가 일치하지 않습니다."
                   FontSize="11" Foreground="#EF4444"
                   Visibility="Collapsed" Margin="2,6,0,0"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="취소" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="16,6" FontSize="12" Margin="0,0,8,0"/>
            <Button Content="확인" IsDefault="True" Click="OnConfirm"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Padding="16,6" FontSize="12"/>
        </StackPanel>
    </StackPanel>
</Window>
