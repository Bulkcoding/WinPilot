<UserControl x:Class="WinPilot.Views.PingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- 결과 행 성공/실패 색상 -->
        <Style x:Key="RttStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#22C55E"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                    <Setter Property="Foreground" Value="#EF4444"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <DockPanel Grid.Row="0" Margin="24,20,24,16">
            <TextBlock Text="Ping 테스트" FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- 입력 + 버튼 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="24,0,24,12">
            <StackPanel>
                <DockPanel>
                    <!-- 중지 버튼 먼저 (Dock Right) -->
                    <Button DockPanel.Dock="Right"
                            Content="■ 중지"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right"
                            Content="▶ 연속 Ping"
                            Command="{Binding StartContinuousCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="12,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right"
                            Content="▷ 단일 Ping"
                            Command="{Binding PingOnceCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,6" Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                    <!-- 입력 필드 -->
                    <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource ItemRowBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                             Padding="10,7" FontSize="13"
                             VerticalContentAlignment="Center"/>
                </DockPanel>
                <TextBlock Text="호스트명 또는 IP 주소 입력 (예: 8.8.8.8, google.com)"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- 요약 -->
        <Border Grid.Row="2" Background="{DynamicResource ItemRowBrush}"
                CornerRadius="6" Margin="24,0,24,12" Padding="14,10">
            <DockPanel>
                <ProgressBar DockPanel.Dock="Right" Width="80" Height="4"
                             IsIndeterminate="{Binding IsRunning}"
                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"
                             Foreground="#3B82F6" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Summary}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="13" FontFamily="Consolas" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- 결과 목록 -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="24,0,24,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 컬럼 헤더 -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#"        Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Column="1" Text="호스트"   Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Column="2" Text="RTT"      Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Column="3" Text="TTL"      Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Column="4" Text="상태"     Style="{StaticResource InfoLabelStyle}"/>
                </Grid>

                <!-- 결과 행 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Results}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="5" CornerRadius="4"
                                            Margin="0,0,0,0" Padding="4,6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                        <Setter Property="Background" Value="#1A0A0A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <TextBlock Grid.Column="0" Text="{Binding Seq}"
                                               Style="{StaticResource RttStyle}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Host}"
                                               FontFamily="Consolas" FontSize="12"
                                               Foreground="{DynamicResource TextValueBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding RttText}"
                                               Style="{StaticResource RttStyle}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding TtlText}"
                                               FontFamily="Consolas" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding StatusText}"
                                               Style="{StaticResource RttStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
