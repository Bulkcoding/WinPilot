<UserControl x:Class="WinPilot.Views.WindowsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- 토글 스위치 -->
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="12"
                                    Background="{DynamicResource ControlBrush}" Width="44" Height="24"/>
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#F97316"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SAC 상태 선택 버튼 (선택된 상태면 파란색) -->
        <Style x:Key="SacStateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Background="{DynamicResource BgBrush}" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- 헤더 -->
            <DockPanel Margin="0,0,0,20">
                <Button DockPanel.Dock="Right" Content="↺ 새로고침"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center"/>
                <TextBlock Text="Windows 설정" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- ═══════════════════════════════════════════ -->
            <!-- 배달 최적화                                  -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="배달 최적화 (Delivery Optimization)"
                               Style="{StaticResource CardTitleStyle}" Margin="0,0,0,4"/>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,16">
                        설정 › Windows 업데이트 › 고급 옵션 › 배달 최적화 › 다른 장치에서 다운로드 허용
                    </TextBlock>

                    <!-- 토글 행 -->
                    <DockPanel Margin="0,0,0,10">
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding DeliveryOptEnabled}"
                                      IsEnabled="{Binding DeliveryOptPolicyLocked,
                                                  Converter={StaticResource InverseBoolConverter}}"
                                      Style="{StaticResource ToggleSwitchStyle}"/>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="다른 장치에서 다운로드 허용"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <ProgressBar Width="60" Height="3" IsIndeterminate="True"
                                             Foreground="#F97316" Margin="0,0,8,0" VerticalAlignment="Center"
                                             Visibility="{Binding DeliveryOptApplying, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="{Binding DeliveryOptStatus}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>

                    <!-- 정책 잠금 경고 -->
                    <Border Visibility="{Binding DeliveryOptPolicyLocked, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource WarningBgBrush}" BorderBrush="#F59E0B"
                            BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,4,0,0">
                        <TextBlock Foreground="#F59E0B" FontSize="12"
                                   Text="⚠ 그룹 정책으로 관리되고 있어 여기서 변경할 수 없습니다."/>
                    </Border>

                    <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6"
                            Padding="12,8" Margin="0,12,0,0">
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}">
                            ℹ  설정은 레지스트리에 즉시 저장됩니다. Windows 설정 앱에서 확인하려면 해당 페이지를 닫았다가 다시 여세요.
                            실제 다운로드 동작 변경은 다음 Windows 업데이트 시점에 적용됩니다.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════ -->
            <!-- 스마트 앱 컨트롤                             -->
            <!-- ═══════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="스마트 앱 컨트롤 (Smart App Control)"
                               Style="{StaticResource CardTitleStyle}" Margin="0,0,0,4"/>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,16">
                        Windows 보안 › 앱 및 브라우저 컨트롤 › 스마트 앱 컨트롤 설정
                    </TextBlock>

                    <!-- 미지원 -->
                    <Border Visibility="{Binding SacSupported, Converter={StaticResource BoolToVisibility},
                                         ConverterParameter=inverse}"
                            Background="{DynamicResource ItemRowBrush}" CornerRadius="6" Padding="14,12">
                        <TextBlock Text="{Binding SacStatusText}"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                    </Border>

                    <!-- 지원 PC -->
                    <StackPanel Visibility="{Binding SacSupported, Converter={StaticResource BoolToVisibility}}">

                        <!-- 현재 상태 표시 -->
                        <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6"
                                Padding="14,12" Margin="0,0,0,16">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Text="{Binding SacStatusText}"
                                           FontSize="14" FontWeight="Bold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SacState}" Value="0">
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SacState}" Value="1">
                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SacState}" Value="2">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="현재 상태:"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <!-- 상태 선택 버튼 3개 -->
                        <TextBlock Text="상태 변경" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <!-- 켜기 -->
                            <Button Content="켜기 (On)" Command="{Binding SetSacCommand}" CommandParameter="2"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource SacStateButtonStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SacState}" Value="2">
                                                <Setter Property="Background" Value="#22C55E"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <!-- 평가 모드 -->
                            <Button Content="평가 모드" Command="{Binding SetSacCommand}" CommandParameter="1"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource SacStateButtonStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SacState}" Value="1">
                                                <Setter Property="Background" Value="#F59E0B"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <!-- 끄기 -->
                            <Button Content="끄기 (Off)" Command="{Binding SetSacCommand}" CommandParameter="0">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource SacStateButtonStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SacState}" Value="0">
                                                <Setter Property="Background" Value="#EF4444"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- 경고 -->
                        <Border Background="{DynamicResource WarningBgBrush}" BorderBrush="#F59E0B"
                                BorderThickness="1" CornerRadius="6" Padding="12,8">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#F59E0B">
                                ⚠ 주의: 끄기로 설정하면 Windows 보안 설정에서 다시 켤 수 없습니다.
                                (레지스트리 수정으로만 복원 가능) 변경 후 재부팅이 필요합니다.
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
