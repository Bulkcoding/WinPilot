<UserControl x:Class="WinPilot.Views.RecoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:WinPilot.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:StepStatusToBrushConverter x:Key="StatusToBrush"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>
    <Grid Background="{DynamicResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <DockPanel Grid.Row="0" Margin="24,20,24,16">
            <TextBlock Text="복구 도구" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
        </DockPanel>

        <!-- 관리자 권한 경고 -->
        <Border Grid.Row="1"
                Visibility="{Binding IsNotAdmin, Converter={StaticResource BoolToVisibility}}"
                Background="{DynamicResource WarningBgBrush}" BorderBrush="#F59E0B" BorderThickness="1"
                CornerRadius="8" Margin="24,0,24,16" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="관리자로 재시작"
                        Command="{Binding RestartAsAdminCommand}"
                        Style="{StaticResource WarningButtonStyle}"/>
                <StackPanel>
                    <TextBlock Text="⚠ 관리자 권한 필요" Foreground="#F59E0B" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="DISM 및 SFC 명령은 관리자 권한으로 실행해야 합니다."
                               Foreground="{DynamicResource TextValueBrush}" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 4단계 + 실행 버튼 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="24,0,24,16">
            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <Button DockPanel.Dock="Right" Content="▶ 전체 실행"
                            Command="{Binding RunAllStepsCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="12,6" FontSize="12"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="시스템 복구 단계" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                </DockPanel>
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource ItemRowBrush}" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="26" Height="26" CornerRadius="13"
                                            Background="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Number}" Foreground="White" FontSize="12"
                                                   FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CommandDisplay}" Foreground="#64748B" FontSize="11"
                                                   FontFamily="Consolas" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                               FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <Button Grid.Column="3"
                                            Content="▶ 실행"
                                            Command="{Binding DataContext.RunStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="10,5" FontSize="11"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 출력 로그:
             CardStyle(Padding=20) 대신 헤더만 Margin으로 패딩 처리.
             TextBox가 카드 하단/우측 끝까지 채워야 스크롤바가 카드 안에 정렬됨. -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="10"
                Margin="24,0,24,24"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="20,20,20,12">
                    <TextBlock Text="실행 결과" Style="{StaticResource CardTitleStyle}"/>
                    <ProgressBar DockPanel.Dock="Right" Width="80" Height="4"
                                 IsIndeterminate="{Binding IsRunning}"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"
                                 Foreground="#F97316"/>
                </DockPanel>
                <TextBox Grid.Row="1"
                         Text="{Binding CurrentOutput, Mode=OneWay}"
                         Background="{DynamicResource ConsoleBgBrush}" Foreground="{DynamicResource ConsoleTextBrush}"
                         FontFamily="Consolas" FontSize="11"
                         IsReadOnly="True" TextWrapping="Wrap"
                         BorderThickness="0" Padding="8"
                         MinHeight="200"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="OutputTextBox_TextChanged"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
